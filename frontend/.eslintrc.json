{
    "env": {
        "browser": true,
        "es2021": true,
        "jest": true
    },
    "extends": [
        "plugin:react/recommended",
        "airbnb",
        "prettier"
    ],
    "parserOptions": {
        "ecmaFeatures": {
            "jsx": true
        },
        "ecmaVersion": 2020,
        "sourceType": "module"
    },
    "plugins": [
        "react",
        "prettier"
    ],
    "rules": {
        "max-len": [
            2,
            100,
            2,
            {
                "ignoreUrls": true,
                "ignoreComments": false
            }
        ],
        "no-restricted-exports": "off",
        "import/prefer-default-export": "off",
        "prettier/prettier": [
            "error",
            {
                "trailingComma": "es5",
                "printWidth": 80,
                "semi": true,
                "bracketSpacing": false,
                "jsxBracketSameLine": true
            }
        ],
        "react/jsx-filename-extension": [
            1,
            {
                "extensions": [
                    ".js",
                    ".jsx"
                ]
            }
        ]
    }
}
